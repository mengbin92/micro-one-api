# Required infrastructure
MYSQL_ROOT_PASSWORD=change-me
DATABASE_DSN=root:change-me@tcp(mysql:3306)/oneapi?charset=utf8mb4&parseTime=True&loc=Local
REDIS_PASSWORD=change-me

# Required service authentication
JWT_SECRET_KEY=change-me-to-a-long-random-string
SERVICE_TOKEN=change-me-to-a-long-random-string
ADMIN_TOKEN=change-me-to-a-long-random-string

# Initial admin bootstrap, first start only
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_EMAIL=admin@example.com
INITIAL_ADMIN_PASSWORD=

# Payment defaults
PAYMENT_QUOTA_PER_UNIT=500000
ALIPAY_ENABLED=false
ALIPAY_FORM_URL=https://openapi-sandbox.dl.alipaydev.com/gateway.do
ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY=
ALIPAY_PRIVATE_KEY_PATH=/cert/alipay/application_private_key.pem
ALIPAY_PUBLIC_KEY=
ALIPAY_PUBLIC_KEY_PATH=/cert/alipay/alipay_public_key.pem
ALIPAY_NOTIFY_URL=
ALIPAY_RETURN_URL=
ALIPAY_APP_CERT_PATH=
ALIPAY_ROOT_CERT_PATH=
ALIPAY_PUBLIC_CERT_PATH=

# Reconciliation alerts
NOTIFY_GRPC_ENDPOINT=notify-worker:9008
RECON_ALERT_ENABLED=true
RECON_ALERT_RECIPIENTS=[admin]
RECON_ALERT_INTERVAL=1h
